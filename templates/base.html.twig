<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"> {% block stylesheets %}{% endblock %}
		<link rel="stylesheet" href="{{ asset('styles/app.scss') }}">
		{% block javascripts %}

			{% block importmap %}

				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body>
		<header>
			<nav class="navbar" id="main-navbar">
				<div class="navbar-container">
					<div class="nav-button-basket">
						<a href="/panier">
							<img src="{{ asset('uploads/images/basket-shopping-solid.svg') }}" alt="Logo Panier">
						</a>
					</div>
					<a href="/" class="nav-logo"><img src="{{ asset('uploads/images/Logo Noir RG Fight Academy.jpg') }}" alt="Logo RG Fight Academy"></a>
					<div class="nav-button">
						<img src="{{ asset('uploads/images/bars-solid.svg') }}" alt="Logo Menu Burger">
					</div>

					<ul class="nav-menu">
						{% if app.user %}
							<li class="nav-item">
								<a href="/profil">Mon Profil</a>
							</li>
							<li class="nav-item">
								<a href="/logout">Se déconnecter</a>
							</li>
						{% else %}
							<li class="nav-item">
								<a href="/register">S'inscrire</a>
							</li>
							<li class="nav-item">
								<a href="/login">Se connecter</a>
							</li>
						{% endif %}
						<li class="nav-item active">
							<a href="/">Accueil</a>
						</li>
						<li class="nav-item">
							<a href="/cours">Cours</a>
						</li>
						<li class="nav-item">
							<a href="/tarifs">Tarifs</a>
						</li>
						<li class="nav-item">
							<a href="/contact">Contact</a>
						</li>
						<li class="nav-item">
							<a href="/boutique">Boutique</a>
						</li>
					</ul>
				</div>
			</nav>
		</header>
		<div class="header_img"><img src="{{ asset('uploads/images/header-photo.jpg') }}" alt=""></div>
		{% block body %}{% endblock %}
	</body>
	<footer>
		<img src="{{ asset('uploads/images/Logo Blanc RG Fight Academy.jpg')}}" alt="Logo RG Fight Academy" class="logo-footer">
		<div>
			<a href="{{ asset("/") }}">Accueil</a>
		</div>
		<div>
			<a href="{{ asset("/cours") }}">Cours</a>
		</div>
		<div>
			<a href="{{ asset("/tarifs") }}">Tarifs</a>
		</div>
		<div>
			<a href="{{ asset("/contact") }}">Contact</a>
		</div>
		<div>
			<a href="{{ asset("/boutique") }}">Boutique</a>
		</div>

		<div>
			<p>
				02 00 00 00 00
				<br>
				Salle des Glycines
				<br>
				Route de Crémieu
				<br>
				38280 Janneyrias
				<br>
			</p>

			<p>Suivez-nous !</p>

			<hr class="separator">

			<p>© 2026 RG FIGHT ACADEMY. Tous droits réservés.</p>
		</div>
	</footer>
</html>
