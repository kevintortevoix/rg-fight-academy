<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="turbo-prefetch" content="false">
		<title>
			{% block title %}Base{% endblock %}
		</title>

		{% block meta_description %}
		<meta name="description" content="RG Fight Academy : Ecole de Jiu-Jitsu Brésilien à Janneyrias. 
		Cours pour enfants et adultes, 
		boutique et réservations en ligne."
		{% endblock %}

		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"> {% block stylesheets %}{% endblock %}
		<link rel="stylesheet" href="{{ asset('styles/app.scss') }}">
		{% block javascripts %}

			{% block importmap %}

				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body>
		<header>
			<nav class="navbar" id="main-navbar">
				<div class="navbar-container">
					<div class="nav-button">
						<img src="{{ asset('uploads/images/bars-solid.svg') }}" alt="Logo Menu Burger">
					</div>
					<a href="/" class="nav-logo"><img src="{{ asset('uploads/images/Logo Noir RG Fight Academy.jpg') }}" alt="Logo RG Fight Academy"></a>
					<div class="nav-button-basket">
						<a href="/panier">
							<img src="{{ asset('uploads/images/basket-shopping-solid.svg') }}" alt="Logo Panier">
						</a>
					</div>
					

					<ul class="nav-menu">
						{% if app.user %}
							<li class="nav-item">
								<a href="/profil">Mon Profil</a>
							</li>
							<li class="nav-item">
								<a href="/logout">Se déconnecter</a>
							</li>
						{% else %}
							<li class="nav-item">
								<a href="/register">S'inscrire</a>
							</li>
							<li class="nav-item">
								<a href="/login">Se connecter</a>
							</li>
						{% endif %}
						<li class="nav-item active">
							<a href="/">Accueil</a>
						</li>
						<li class="nav-item">
							<a href="/cours">Cours</a>
						</li>
						<li class="nav-item">
							<a href="/tarifs">Tarifs</a>
						</li>
						<li class="nav-item">
							<a href="/contact">Contact</a>
						</li>
						<li class="nav-item">
							<a href="/boutique">Boutique</a>
						</li>
					</ul>
				</div>
			</nav>
		</header>
		<div class="header_img"><img src="{{ asset('uploads/images/header-photo.jpg') }}" alt=" Deux jiujitsuka"></div>
		{% block body %}{% endblock %}
	</body>
	<footer>
    <img src="{{ asset('uploads/images/Logo Blanc RG Fight Academy.jpg')}}" alt="Logo RG Fight Academy" class="logo-footer">

    <div class="footer-nav">
        <div><a href="/">Accueil</a></div>
        <div><a href="/cours">Cours</a></div>
        <div><a href="/tarifs">Tarifs</a></div>
        <div><a href="/contact">Contact</a></div>
        <div><a href="/boutique">Boutique</a></div>
    </div>

    <div class="footer-contact">
        <p>
            06 49 83 67 98<br>
            Salle des Glycines<br>
            37 place Jean Moulin<br>
            38280 Janneyrias
        </p>
    </div>

    <div class="footer-social-col">
        <p>Suivez-nous !</p>
        <div class="social-links">
            <a href="https://www.facebook.com/RGFightAcademy" target="_blank">
                <img src="{{ asset('uploads/images/facebook_logo_2.svg') }}" alt="Facebook" width="25">
            </a>
            <a href="https://www.instagram.com/rg_fight_academy" target="_blank">
                <img src="{{ asset('uploads/images/instagram_logo.svg') }}" alt="Instagram" width="25">
            </a>
            <a href="https://share.google/cV7k3gLxEOWMiNJpg" target="_blank">
                <img src="{{ asset('uploads/images/google_logo.svg') }}" alt="Google" width="25">
            </a>
        </div>
    </div>

    <hr class="separator">

	<div class="legal">
	<a  href="{{ path('app_mentions_legales') }}">Mentions Légales</a>
	<a  href="{{ path('app_politique_confidentialite') }}">Politique de Confidentialité</a> 
	</div> 
	
    <p class="footer-copy">© 2026 RG FIGHT ACADEMY. Tous droits réservés.</p>
	
</footer>
</html>
