<form method="post" action="{{ path('app_commande_delete', {'id': commande.id}) }}" onsubmit="return confirm('Etes-vous sur de vouloir supprimé cette commande ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">
    <button class="btn-dark">Supprimé la commande</button>
</form>
