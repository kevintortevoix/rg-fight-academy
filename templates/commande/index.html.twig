{% extends 'base.html.twig' %}

{% block title %}Commande index
{% endblock %}

{% block body %}
	<h1>Commande index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>DateCommande</th>
				<th>Statut</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for commande in commandes %}
				<tr>
					<td>{{ commande.id }}</td>
					<td>{{ commande.dateCommande ? commande.dateCommande|date('Y-m-d') : '' }}</td>
					<td>{{ commande.statut }}</td>
					<td>
						<a href="{{ path('app_commande_show', {'id': commande.id}) }}">Voir la commande</a>
						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('app_commande_edit', {'id': commande.id}) }}">edit</a>
						{% endif %}
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="4">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	{% if is_granted('ROLE_ADMIN') %}
		<a href="{{ path('app_commande_new') }}">Create new</a>
	{% endif %}
{% endblock %}
