{% extends 'base.html.twig' %}

{% block title %}Mes commandes{% endblock %}

{% block body %}
<div class="reservations-container">
    <h2>Mes commandes</h2>

    <div class="reservations-grid">
        {% for commande in commandes %}
            <div class="reservation-card">
                <div class="reservation-card-header">
                    Commande #{{ commande.id }}
                </div>
                <div class="reservation-card-body">
                    <p>
                        <span class="label">Date :</span>
                        {{ commande.dateCommande ? commande.dateCommande|date('d/m/Y') : 'Non définie' }}
                    </p>
                    <p>
                        <span class="label">Statut :</span>
                        {{ commande.statut }}
                    </p>
                </div>
                <div class="reservation-card-footer">
                    <a href="{{ path('app_commande_show', {'id': commande.id}) }}" class="btn-dark">Voir la commande</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn-dark">Modifier</a>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <p class="no-reservation">Vous n'avez aucune commande.</p>
        {% endfor %}
    </div>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_commande_new') }}" class="btn-retour">Créer une commande</a>
    {% endif %}
</div>
{% endblock %}