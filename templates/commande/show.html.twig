{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}
{% endblock %}

{% block body %}
	<h1>Commande #{{ commande.id }}</h1>

	{% for message in app.flashes ("success") %}
		<div class="flash-success">
			{{message}}
		{% endfor %}
	</div>

	<p>
		<strong>Date :</strong>
		{{ commande.dateCommande ? commande.dateCommande|date('d-m-Y') : 'Non définie' }}</p>

	<table class="table-basket">
		<thead>
			<tr>
				<th>Produit</th>
				<th>Taille</th>
				<th>Quantité</th>
				<th>Prix unitaire (€)</th>
				<th>Total produit (€)</th>
			</tr>
		</thead>
		<tbody>
			{% set totalCommande = 0 %}
			{% for cp in commande.commandeProduits %}
				{% set totalProduit = cp.quantite * cp.prixUnitaire %}
				{% set totalCommande = totalCommande + totalProduit %}
				<tr>
					<td>{{ cp.produit.nom }}</td>
					<td>{{ cp.taille ?? '-' }}</td>
					<td>{{ cp.quantite }}</td>
					<td>{{ cp.prixUnitaire }}</td>
					<td>{{ totalProduit }}</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">Aucun produit commandé</td>
				</tr>
			{% endfor %}
		</tbody>
		<tfoot>
			<tr>
				<th colspan="3" class="text-end">Total général :</th>
				<th>{{ totalCommande }}</th>
			</tr>
		</tfoot>
	</table>

	<a href="{{ path('app_commande_index') }}" class="btn-dark">Mes commandes</a>

	{% if is_granted('ROLE_ADMIN') %}
		<a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn-dark">Editer la commande</a>
	{% endif %}

	{% if is_granted('ROLE_ADMIN') %}
		{{ include('commande/_delete_form.html.twig') }}
	{% endif %}
{% endblock %}
