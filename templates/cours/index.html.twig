{% extends 'base.html.twig' %}

{% block title %}Cours
{% endblock %}

{% block body %}


	<h1>Nos Cours</h1>

	<section class="cours">
		<div class="cours-card">
			<p>🐣 Baby’s (3 – 6 ans)</p>
			<p>Découverte & motricité par le jeu</p>
			<p>Nos cours Baby’s initient les tout-petits au Jiu-Jitsu à travers des jeux ludiques et éducatifs. 
										L’objectif est de développer la coordination, 
										l’équilibre et la confiance en soi dans un environnement sécurisé et bienveillant.</p>
			<p>	✔ Développement moteur <br>
				✔ Apprentissage du respect et de la discipline <br>
				✔ Jeux d’opposition adaptés <br>
				✔ Socialisation et confiance en soi <br>
			</p>
			<p>Un premier pas dans les arts martiaux en douceur et en s’amusant.</p>
			<a href="" class="btn-dark">Tarifs</a>
		</div>
	</section>

	<section class="cours">
		<div class="cours-card">
			<p>🥋 Kid’s (6 – 9 ans)</p>
			<p>Le programme Kid’s permet aux enfants d’apprendre les fondamentaux du JJB tout en développant discipline,
										concentration et esprit d’équipe.</p>
			<p>✔ Techniques de base (positions, contrôles, défenses) <br>
										✔ Coordination et agilité <br>
										✔ Respect des règles et des partenaires <br>
										✔ Progression par ceintures <br>
			</p>
			<p>Un cadre structurant pour évoluer tout en prenant du plaisir.</p>
			<a href="" class="btn-dark">Tarifs</a>
		</div>
	</section>

	<section class="cours">
		<div class="cours-card">
			<p>🔥 Ado (9 – 13 ans)</p>
			<p>Technique, stratégie & dépassement de soi
								Ce programme est conçu pour accompagner les jeunes dans leur progression technique et mentale. 
								Les cours sont plus structurés, avec un travail stratégique et une préparation physique adaptée.</p>
			<p>✔ Perfectionnement technique <br>
								✔ Introduction à la stratégie de combat <br>
								✔ Développement de la condition physique <br>
								✔ Préparation à la compétition (optionnelle) <br>
			</p>
			<p>
				Un programme idéal pour canaliser l’énergie et développer la confiance.</p>
			<a href="" class="btn-dark">Tarifs</a>
		</div>
	</section>

	<section class="cours">
		<div class="cours-card">
			<p>💪 Adultes</p>
			<p>Tous niveaux – Loisir & compétition</p>
			<p>Que vous soyez débutant ou pratiquant confirmé, le programme adultes s’adapte à votre niveau et à vos objectifs.</p>
			<p>✔ Apprentissage complet du JJB <br> 
					✔ Travail technique et sparring encadré <br>
					✔ Ambiance conviviale et motivante <br>
					✔ Préparation compétition possible <br> </p>
			<p>Se dépasser, apprendre et progresser dans une ambiance d’équipe.</p>
			<a href="" class="btn-dark">Tarifs</a>
		</div>
	</section>

	<section class="cours">
		<div class="cours-card">
			<p>🏋️ Préparation Physique</p>
			<p>Performance, force & endurance</p>
			<p>Programme dédié à l’amélioration des qualités physiques spécifiques au Jiu-Jitsu Brésilien.</p>
			<p>✔ Renforcement musculaire fonctionnel <br>
					✔ Travail cardio & explosivité <br>
					✔ Prévention des blessures <br>
					✔ Amélioration de la mobilité <br> </p>
			<p>Optimisez vos performances sur le tatami.</p>
			<a href="" class="btn-dark">Tarifs</a>
		</div>
	</section>
{% endblock %}
