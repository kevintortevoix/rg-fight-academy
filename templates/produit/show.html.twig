{% extends 'base.html.twig' %}

{% block title %}{{ produit.nom }}{% endblock %}

{% block body %}
<div class="produit-show">
    <div class="card">
        <img src="{{ asset('uploads/images/' ~ produit.image) }}" alt="{{ produit.nom }}">
        <h3>{{ produit.nom }}</h3>
        <p>{{ produit.prix }} €</p>
        <p>{{ produit.description }}</p>

        <form method="post" action="{{ path('panier_ajouter', {id: produit.id}) }}">
            <label for="taille">Choisir une taille :</label>
            <select name="taille" id="taille" required>
                <option value="">-- Sélectionner --</option>
                {% for taille in produit.produitTailles %}
                    <option value="{{ taille.taille }}" {% if taille.stock == 0 %}disabled{% endif %}>
                        {{ taille.taille }} {% if taille.stock == 0 %}(Rupture de stock){% endif %}
                    </option>
                {% endfor %}
            </select>
            <button type="submit" class="btn-dark">Ajouter au panier</button>
        </form>

        <a href="{{ path('app_produit_index') }}" class="btn-dark">Retour à la boutique</a>
    </div>
</div>
{% endblock %}