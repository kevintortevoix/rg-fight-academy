{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="profil-container">

    <div class="profil-header">
        <h1>{{ user.prenom }} {{ user.nom }}</h1>
        <p class="profil-email">{{ user.email }}</p>
    </div>

    <div class="profil-grid">

        <a href="/commande" class="profil-card">
            <span class="profil-card-label">Mes commandes</span>
        </a>

        <a href="/reservations" class="profil-card">
            <span class="profil-card-label">Mes réservations</span>
        </a>

        {% if is_granted('ROLE_ADMIN') %}
        <a href="/admin" class="profil-card profil-card--admin">
            <span class="profil-card-label">Espace admin</span>
        </a>
        {% endif %}

    </div>

    <a href="/logout" class="btn-dark">Déconnexion</a>

</div>
{% endblock %}